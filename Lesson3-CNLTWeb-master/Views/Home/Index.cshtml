@{
    ViewData["Title"] = "Trang Chủ Thống Kê";
}

<div class="container mt-4">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="bi bi-building"></i> Hệ Thống Quản Lý Phòng Trọ
            </h1>
            <p class="lead text-muted">
                Đồ án môn học Công nghệ lập trình Web <br />
                Sinh viên thực hiện: <strong class="text-dark">Lại Xuân Biển (BIT240041)</strong>
            </p>
            <hr class="w-50 mx-auto mt-4 mb-5">
        </div>
    </div>

    <div class="row g-4 justify-content-center">

        <div class="col-md-4">
            <div class="card bg-info text-white h-100 shadow-sm border-0 rounded-4 overflow-hidden custom-hover-card">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-bold mb-0">Loại Phòng</h5>
                        <i class="bi bi-tags fs-1 opacity-50 position-absolute" style="top: 20px; right: 20px;"></i>
                    </div>
                    <h2 class="display-3 fw-bold mb-0">@ViewBag.TotalRoomTypes</h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a asp-controller="RoomTypes" asp-action="Index" class="text-white text-decoration-none fw-bold">
                        Quản lý ngay <i class="bi bi-arrow-right-circle ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-primary text-white h-100 shadow-sm border-0 rounded-4 overflow-hidden custom-hover-card">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-bold mb-0">Tổng Số Phòng</h5>
                        <i class="bi bi-door-open fs-1 opacity-50 position-absolute" style="top: 20px; right: 20px;"></i>
                    </div>
                    <h2 class="display-3 fw-bold mb-0">@ViewBag.TotalRooms</h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a asp-controller="Rooms" asp-action="Index" class="text-white text-decoration-none fw-bold">
                        Xem danh sách <i class="bi bi-arrow-right-circle ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-success text-white h-100 shadow-sm border-0 rounded-4 overflow-hidden custom-hover-card">
                <div class="card-body p-4 position-relative">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-bold mb-0">Phòng Trống</h5>
                        <i class="bi bi-check-circle fs-1 opacity-50 position-absolute" style="top: 20px; right: 20px;"></i>
                    </div>
                    <h2 class="display-3 fw-bold mb-0">@ViewBag.AvailableRooms</h2>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a asp-controller="Rooms" asp-action="Index" asp-route-isAvailable="true" class="text-white text-decoration-none fw-bold">
                        Lọc phòng trống <i class="bi bi-arrow-right-circle ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .custom-hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .custom-hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }
</style>