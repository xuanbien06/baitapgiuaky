@model IEnumerable<Lesson3_ORM_BookManagement.Models.Room_BIT240041>
@{
    ViewData["Title"] = "Danh sách Phòng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-door-open"></i> Quản lý Phòng Trọ</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Thêm Phòng Mới
    </a>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">Tên phòng</label>
                    <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Nhập tên..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">Loại phòng</label>
                    <select name="roomTypeId" asp-items="ViewBag.RoomTypes" class="form-select">
                        <option value="">-- Tất cả --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">Trạng thái</label>
                    <select name="isAvailable" asp-items="ViewBag.IsAvailableList" class="form-select">
                        <option value="">-- Tất cả --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">Giá tối đa (VNĐ)</label>
                    <input type="number" name="maxPrice" value="@ViewData["CurrentMaxPrice"]" class="form-control" placeholder="VD: 3000000" />
                </div>
                <div class="col-md-2">
                    <label class="form-label fw-bold text-muted small">Sắp xếp theo</label>
                    <select name="sortOrder" asp-items="ViewBag.SortList" class="form-select">
                        <option value="">-- Mặc định --</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary shadow-sm flex-grow-1"><i class="bi bi-search"></i> Lọc</button>
                    <a asp-action="Index" class="btn btn-secondary shadow-sm" title="Xóa lọc"><i class="bi bi-arrow-clockwise"></i></a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Ảnh</th>
                        <th>Tên Phòng</th>
                        <th>Loại Phòng</th>
                        <th class="text-end">Giá Thuê</th>
                        <th class="text-end">Diện Tích</th>
                        <th class="text-end">Giá/m²</th>
                        <th class="text-center">Trạng Thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-danger fw-bold py-4">Không tìm thấy phòng nào phù hợp!</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var thumbnailObj = item.RoomImages?.FirstOrDefault(i => i.IsThumbnail);
                            var thumbUrl = thumbnailObj != null ? thumbnailObj.ImageUrl : "https://via.placeholder.com/80x60?text=No+Image";

                            // GIAI ĐOẠN 8: TÍNH TOÁN GIÁ TRÊN MÉT VUÔNG (Chỉ tính lúc hiển thị)
                            decimal pricePerM2 = item.Area > 0 ? item.Price / (decimal)item.Area : 0;

                            <tr>
                                <td class="text-center">
                                    <img src="@thumbUrl" alt="Room Image" class="img-thumbnail shadow-sm" style="width: 80px; height: 60px; object-fit: cover;" />
                                </td>
                                <td class="fw-bold">@item.Name</td>
                                <td><span class="badge bg-info text-dark">@item.RoomType?.Name</span></td>
                                <td class="text-end text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                                <td class="text-end">@item.Area m²</td>
                                <td class="text-end text-success fw-bold">@pricePerM2.ToString("N0") đ</td>
                                <td class="text-center">
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success shadow-sm"><i class="bi bi-check-circle"></i> Còn</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary shadow-sm"><i class="bi bi-lock-fill"></i> Hết</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="RoomImages" asp-action="Index" asp-route-roomId="@item.Id" class="btn btn-sm btn-outline-success" title="Quản lý Ảnh">
                                            <i class="bi bi-images"></i>
                                        </a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-pencil-square"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>