@model Lesson3_ORM_BookManagement.Models.Room_BIT240041
@{
    ViewData["Title"] = "Xóa Phòng";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="alert alert-danger shadow-sm border-0" role="alert">
            <h4 class="alert-heading fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo nguy hiểm!</h4>
            <p>Bạn có chắc chắn muốn xóa dữ liệu của <strong>@Model.Name</strong> không? Thao tác này sẽ xóa vĩnh viễn dữ liệu khỏi hệ thống và không thể phục hồi.</p>
            <hr>
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-end gap-2 mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i> Hủy bỏ</a>
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Xác nhận Xóa</button>
                </div>
            </form>
        </div>
    </div>
</div>