@model Lesson3_ORM_BookManagement.Models.Room_BIT240041
@{
    ViewData["Title"] = "Chi tiết Phòng";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-info text-white py-3">
                <h4 class="mb-0 fw-bold"><i class="bi bi-info-circle"></i> Thông tin chi tiết</h4>
            </div>
            <div class="card-body p-4">
                <ul class="list-group list-group-flush fs-5">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-muted">Tên phòng:</span>
                        <span class="fw-bold text-primary">@Model.Name</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-muted">Loại phòng:</span>
                        <span class="badge bg-secondary">@Model.RoomType?.Name</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-muted">Giá thuê:</span>
                        <span class="fw-bold text-danger">@Model.Price.ToString("N0") VNĐ</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-muted">Diện tích:</span>
                        <span>@Model.Area m²</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-muted">Trạng thái:</span>
                        @if (Model.IsAvailable)
                        {
                            <span class="text-success fw-bold"><i class="bi bi-check-circle"></i> Đang trống</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold"><i class="bi bi-lock-fill"></i> Đã thuê</span>
                        }
                    </li>
                </ul>
                <hr class="my-4">
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning"><i class="bi bi-pencil-square"></i> Sửa thông tin</a>
                </div>
            </div>
        </div>
    </div>
</div>