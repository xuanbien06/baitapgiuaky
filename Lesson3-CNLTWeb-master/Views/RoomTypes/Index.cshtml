@model IEnumerable<Lesson3_ORM_BookManagement.Models.RoomType_BIT240041>
@{
    ViewData["Title"] = "Loại Phòng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold"><i class="bi bi-tags"></i> Quản lý Loại Phòng</h2>
    <a asp-action="Create" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-circle"></i> Thêm Loại Mới
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 10%" class="text-center">ID</th>
                    <th style="width: 40%">Tên Loại Phòng</th>
                    <th style="width: 20%" class="text-center">Số lượng phòng</th>
                    <th style="width: 30%" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-center fw-bold">@item.Id</td>
                        <td class="fw-bold text-primary">@item.Name</td>
                        <td class="text-center">
                            <span class="badge bg-secondary fs-6">
                                @(item.Rooms != null ? item.Rooms.Count : 0) phòng
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>